rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Collection users - accès pour les utilisateurs authentifiés
    match /users/{userId} {
      // L'utilisateur peut lire/écrire ses propres données
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Les utilisateurs authentifiés peuvent lire tous les users (pour la liste)
      allow read: if request.auth != null;
    }
    
    // Collection agency_commissions - accès pour les utilisateurs authentifiés
    match /agency_commissions/{year} {
      allow read, write: if request.auth != null;
    }
  }
}
